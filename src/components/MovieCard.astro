---
interface Props {
    slug: string;
    title: string;
    poster?: string;
    showDate: string;
    showTime?: string;
    showEndTime?: string;
    country?: string;
    duration?: number;
}

const {
    slug,
    title,
    poster,
    showDate,
    showTime,
    showEndTime,
    country,
    duration,
} = Astro.props;

const showDateParsed = new Date(showDate);
showDateParsed.setHours(0, 0, 0, 0);
const today = new Date();
today.setHours(0, 0, 0, 0);

const status = showDateParsed < today ? "past" : "current";

const statusLabel: Record<string, string> = {
    current: "En cartelera",
    next: "Próxima",
    past: "Pasada",
};

const formattedDate = new Date(showDate).toLocaleDateString("es-MX", {
    weekday: "short",
    day: "numeric",
    month: "short",
});

import { Image } from "astro:assets";
---

<a
    href={`/peliculas/${slug}`}
    class="card"
    aria-label={`${title} — ${formattedDate}${showTime ? " " + showTime : ""}`}
>
    <div class="card-poster">
        {
            poster ? (
                <Image
                    src={poster}
                    alt={`Poster: ${title}`}
                    inferSize={true}
                    loading="lazy"
                />
            ) : (
                <div class="card-poster-placeholder" aria-hidden="true">
                    🎬
                </div>
            )
        }
        {
            status !== "past" && (
                <span class="card-badge">{statusLabel[status]}</span>
            )
        }
    </div>
    <div class="card-body">
        <h3 class="card-title">{title}</h3>

        {
            showTime && (
                <div class="card-time-row">
                    <span class="card-time">
                        {showTime} {showEndTime ? ` - ${showEndTime}` : ""}
                    </span>
                    {!showEndTime && <span class="card-time-label">hrs</span>}
                </div>
            )
        }

        <p class="card-date">{formattedDate}</p>

        {
            (country || duration) && (
                <p class="card-meta">
                    {[country, duration ? `${duration} min` : null]
                        .filter(Boolean)
                        .join(" · ")}
                </p>
            )
        }
    </div>
</a>
