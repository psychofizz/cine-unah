---
interface Props {
    slug: string;
    title: string;
    poster?: string;
    showDate: string;
    showTime?: string;
    showEndTime?: string;
    country?: string;
    duration?: number;
    location?: any;
    isPartOfEvent?: any;
    cancelled?: boolean;
}

const {
    slug,
    title,
    poster,
    showDate,
    showTime,
    showEndTime,
    country,
    duration,
    location,
    isPartOfEvent,
    cancelled,
} = Astro.props;

const tz = "America/Tegucigalpa";

const formattedDate = new Date(showDate).toLocaleDateString("es-MX", {
    timeZone: tz,
    weekday: "short",
    day: "numeric",
    month: "short",
});

import { Image } from "astro:assets";
---

<a
    href={`/peliculas/${slug}`}
    class="card"
    data-date={showDate}
    data-time={showTime || ""}
    data-end-time={showEndTime || ""}
    aria-label={`${title} — ${formattedDate}${showTime ? " " + showTime : ""}`}
>
    <div class="card-poster">
        {
            poster ? (
                <Image
                    src={poster}
                    alt={`Poster: ${title}`}
                    width={400}
                    height={600}
                    loading="lazy"
                />
            ) : (
                <div class="card-poster-placeholder" aria-hidden="true">
                    🎬
                </div>
            )
        }
        {
            isPartOfEvent && (
                <div class="card-event-badge">
                    ⚡ Función Doble
                </div>
            )
        }
        {
            // We'll initially render a hidden badge.
            // The client-side script will populate and show it.
        }
        <span class="card-badge" style="display: none;"></span>
        {
            cancelled && (
                <div class="card-cancelled-badge" aria-label="Proyección cancelada">
                    CANCELADA
                </div>
            )
        }
    </div>
    <div class="card-body">
        <h3 class="card-title">{title}</h3>

        {
            showTime && (
                <div class="card-time-row">
                    <span class="card-time">
                        {showTime} {showEndTime ? ` - ${showEndTime}` : ""}
                    </span>
                    {!showEndTime && <span class="card-time-label">hrs</span>}
                </div>
            )
        }

        <p class="card-date">{formattedDate}</p>

        {
            (country || duration || location) && (
                <p class="card-meta">
                    {[country, duration ? `${duration} min` : null, typeof location === 'object' ? location?.title : location]
                        .filter(Boolean)
                        .join(" · ")}
                </p>
            )
        }
    </div>
</a>
