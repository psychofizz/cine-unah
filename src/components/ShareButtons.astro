---
// ShareButtons.astro
// Share row with Web Share API (native) + WhatsApp, Facebook, copy-link fallbacks

interface Props {
    title: string;
    url?: string;
    text?: string;
}

const { title, text = title } = Astro.props;
---

<div class="share-section" id="share-section">
    <p class="share-label">Compartir</p>
    <div class="share-buttons" id="share-buttons">
        <!-- Native share button (shown only if Web Share API available) -->
        <button
            id="btn-native-share"
            class="share-btn share-btn--native"
            aria-label="Compartir"
            style="display:none"
        >
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
            >
                <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"></path>
                <polyline points="16 6 12 2 8 6"></polyline>
                <line x1="12" y1="2" x2="12" y2="15"></line>
            </svg>
            Compartir
        </button>

        <!-- WhatsApp -->
        <a
            id="btn-whatsapp"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-btn--whatsapp"
            aria-label="Compartir en WhatsApp"
        >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"
                ></path>
                <path
                    d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L.057 23.57a.5.5 0 00.613.612l5.792-1.463A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.96 0-3.788-.527-5.364-1.44l-.383-.228-3.97 1.003 1.028-3.858-.247-.397A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
                ></path>
            </svg>
            WhatsApp
        </a>

        <!-- Facebook -->
        <a
            id="btn-facebook"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-btn--facebook"
            aria-label="Compartir en Facebook"
        >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                ></path>
            </svg>
            Facebook
        </a>

        <!-- Copy link -->
        <button
            id="btn-copy-link"
            class="share-btn share-btn--copy"
            aria-label="Copiar enlace"
        >
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
            >
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                ></path>
            </svg>
            <span id="copy-label">Copiar enlace</span>
        </button>
    </div>
</div>

<script define:vars={{ title, text }}>
    (function () {
        const pageUrl = window.location.href;

        // ── Native Share (Web Share API) ──────────
        const nativeBtn = document.getElementById("btn-native-share");
        if (nativeBtn && navigator.share) {
            nativeBtn.style.display = "flex";
            nativeBtn.addEventListener("click", async () => {
                try {
                    await navigator.share({ title, text, url: pageUrl });
                } catch (_) {
                    /* user cancelled */
                }
            });
        }

        // ── WhatsApp ───────────────────────────────
        const waBtn = document.getElementById("btn-whatsapp");
        if (waBtn) {
            waBtn.href = `https://wa.me/?text=${encodeURIComponent(text + " — " + pageUrl)}`;
        }

        // ── Facebook ───────────────────────────────
        const fbBtn = document.getElementById("btn-facebook");
        if (fbBtn) {
            fbBtn.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
        }

        // ── Copy Link ──────────────────────────────
        const copyBtn = document.getElementById("btn-copy-link");
        const copyLabel = document.getElementById("copy-label");
        if (copyBtn && copyLabel) {
            copyBtn.addEventListener("click", async () => {
                try {
                    await navigator.clipboard.writeText(pageUrl);
                    copyLabel.textContent = "¡Copiado!";
                    setTimeout(() => {
                        copyLabel.textContent = "Copiar enlace";
                    }, 2000);
                } catch (_) {
                    // Fallback for older browsers
                    const el = document.createElement("textarea");
                    el.value = pageUrl;
                    document.body.appendChild(el);
                    el.select();
                    document.execCommand("copy");
                    document.body.removeChild(el);
                    copyLabel.textContent = "¡Copiado!";
                    setTimeout(() => {
                        copyLabel.textContent = "Copiar enlace";
                    }, 2000);
                }
            });
        }
    })();
</script>
