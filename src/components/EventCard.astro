---
interface Props {
    slug: string;
    title: string;
    poster?: string;
    date: string;
    eventTime?: string;
    eventEndTime?: string;
    location?: string;
}

const { slug, title, poster, date, eventTime, eventEndTime, location } =
    Astro.props;

const formattedDate = new Date(date).toLocaleDateString("es-MX", {
    timeZone: "America/Tegucigalpa",
    weekday: "short",
    day: "numeric",
    month: "short",
});

import { Image } from "astro:assets";
---

<a
    href={`/eventos/${slug}`}
    class="card"
    aria-label={`${title} — ${formattedDate}${eventTime ? " " + eventTime : ""}`}
>
    <div class="card-poster">
        {
            poster ? (
                <Image
                    src={poster}
                    alt={`Poster: ${title}`}
                    width={400}
                    height={600}
                    loading="lazy"
                />
            ) : (
                <div class="card-poster-placeholder" aria-hidden="true">
                    🎭
                </div>
            )
        }
        <span class="card-badge">Evento</span>
    </div>
    <div class="card-body">
        <h3 class="card-title">{title}</h3>

        {
            eventTime && (
                <div class="card-time-row">
                    <span class="card-time">
                        {eventTime} {eventEndTime ? ` - ${eventEndTime}` : ""}
                    </span>
                    {!eventEndTime && <span class="card-time-label">hrs</span>}
                </div>
            )
        }

        <p class="card-date">{formattedDate}</p>
        {location && <p class="card-meta">{location}</p>}
    </div>
</a>
