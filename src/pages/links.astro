---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>cine_unah | Enlaces</title>
    <style>
      body {
        background-color: #050505;
        color: #fff;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 0;
        padding: 24px;
      }
      .top-nav {
        width: 100%;
        max-width: 600px;
        display: flex;
        justify-content: flex-end;
        margin-bottom: 24px;
      }
      .icon-btn {
        background: rgba(255, 255, 255, 0.08);
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        transition: background 0.2s ease;
      }
      .icon-btn:hover {
        background: rgba(255, 255, 255, 0.15);
      }
      .profile-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 24px;
      }
      .avatar-wrapper {
        width: 104px;
        height: 104px;
        border-radius: 50%;
        background: #fff; /* White ring effect */
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
      }
      .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: contain;
        background: #000;
      }
      .username {
        font-family: var(--font-sans);
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 6px 0;
        letter-spacing: -0.02em;
      }
      .bio {
        font-family: var(--font-sans);
        font-size: 15px;
        color: #ececec;
        margin: 0;
        font-weight: 400;
      }
      .social-row {
        display: flex;
        gap: 20px;
        margin-bottom: 32px;
      }
      .social-icon {
        color: #fff;
        opacity: 0.9;
        transition:
          opacity 0.2s,
          transform 0.2s;
      }
      .social-icon:hover {
        opacity: 1;
        transform: translateY(-2px);
      }
      .social-icon svg {
        width: 24px;
        height: 24px;
      }
      .links-container {
        width: 100%;
        max-width: 600px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .link-card {
        display: flex;
        align-items: center;
        background: #1a1a1a;
        border-radius: 30px;
        padding: 6px 16px 6px 6px;
        text-decoration: none;
        color: #fff;
        transition:
          transform 0.2s,
          background 0.2s;
      }
      .link-card:hover {
        transform: scale(1.02);
        background: #252525;
      }
      .link-icon-svg {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        margin-left: 8px;
        color: #fff;
      }
      .link-icon-svg svg {
        width: 100%;
        height: 100%;
      }
      .link-title {
        font-family: var(--font-sans);
        flex: 1;
        text-align: center;
        font-weight: 500;
        font-size: 15px;
        padding-right: 22px;
      }
    </style>
  </head>
  <body>
    <!-- TOP NAV -->
    <div class="top-nav">
      <button class="icon-btn" id="share-btn" aria-label="Copy Link" title="Copiar enlace">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
      </button>
    </div>

    <!-- PROFILE -->
    <div class="profile-section">
      <div class="avatar-wrapper">
        <img src="/uploads/cine-salvador.webp" alt="Cine Francisco Salvador" class="avatar" />
      </div>
      <h1 class="username">cine_unah</h1>
      <p class="bio">Redes sociales del Cine Francisco Salvador</p>
    </div>

    <!-- SOCIAL ICONS -->
    <div class="social-row">
      <a
        href="https://instagram.com/cine_unah"
        class="social-icon"
        aria-label="Instagram"
        target="_blank"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
      </a>
      <a
        href="https://tiktok.com/@cine_unah"
        class="social-icon"
        aria-label="TikTok"
        target="_blank"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path><path d="M15 4v12a4 4 0 0 1-4 4"></path><path d="M15 8a4 4 0 0 0 4 4"></path></svg>
      </a>
      <a
        href="https://youtube.com/cine_unah"
        class="social-icon"
        aria-label="YouTube"
        target="_blank"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
      </a>
      <a
        href="https://wa.me/"
        class="social-icon"
        aria-label="WhatsApp"
        target="_blank"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
      </a>
      <a
        href="https://facebook.com/profile.php?id=61553719695216"
        class="social-icon"
        aria-label="Facebook"
        target="_blank"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
      </a>
    </div>

    <!-- LINKS -->
    <div class="links-container">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="link-card"
            target={link.href.startsWith("http") ? "_blank" : "_self"}
          >
            <div class="link-icon-svg" set:html={link.svg} />
            <span class="link-title">{link.text}</span>
          </a>
        ))
      }
    </div>
    
    <script>
      const shareBtn = document.getElementById("share-btn");
      if (shareBtn) {
        shareBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(window.location.href);
            const originalHTML = shareBtn.innerHTML;
            shareBtn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            setTimeout(() => {
              shareBtn.innerHTML = originalHTML;
            }, 2000);
          } catch (err) {
            console.error("Failed to copy", err);
          }
        });
      }
    </script>
  </body>
</html>
