---
import "../styles/global.css";

const links = [
  {
    text: "Cartelera",
    href: "/",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline><line x1="12" y1="12" x2="12" y2="12"></line><line x1="12" y1="17" x2="12" y2="17"></line></svg>`
  },
  {
    text: "Biblioteca de Cine",
    href: "https://sites.google.com/view/biblioteca-de-cine/home",
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>`
  },
  {
