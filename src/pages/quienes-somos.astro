---
import BaseLayout from "../layouts/BaseLayout.astro";
import { client } from "../../tina/__generated__/client";
import { renderRichText } from "../lib/renderRichText";

let qs: any = null;
try {
  const result = await client.queries.quienesSomos({
    relativePath: "index.md",
  });
  qs = result.data?.quienesSomos;
} catch (e) {
  console.error("Error fetching Quienes Somos:", e);
}

const contentHtml = qs?.content ? renderRichText(qs.content) : "";
---

<BaseLayout
  title={qs?.title ?? "¿Quiénes Somos?"}
  description="Conoce más sobre la comunidad del Cine Universitario en la UNAH."
  image={qs?.image}
  pathname="/quienes-somos"
>
  <div class="container qs-page">
    <div class="detail-page">
      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        Regresar
      </a>

      <article class="qs-content">
        {qs?.image && (
          <div class="qs-hero">
            <img src={encodeURI(qs.image)} alt={qs.title} class="qs-hero-img" />
            <div class="qs-hero-overlay">
              <h1 class="qs-title">{qs?.title}</h1>
            </div>
          </div>
        )}

        {!qs?.image && <h1 class="qs-title qs-title--plain">{qs?.title}</h1>}

        <div class="rich-text-container" set:html={contentHtml} />
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .qs-page {
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .qs-content {
    background: var(--color-bg-card);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .qs-hero {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
  }

  .qs-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .qs-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 40px;
  }

  .qs-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 800;
    color: var(--color-white);
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .qs-title--plain {
    padding: 48px 60px 0;
  }

  .rich-text-container {
    padding: 48px 60px 60px;
    color: var(--color-off-white);
    font-size: 1.2rem;
    line-height: 1.85;
    max-width: 800px;
  }

  .rich-text-container :global(h2) {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-white);
    letter-spacing: -0.01em;
  }

  .rich-text-container :global(h3) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-white);
  }

  .rich-text-container :global(p) {
    margin-bottom: 1.4rem;
  }

  .rich-text-container :global(ul),
  .rich-text-container :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .rich-text-container :global(li) {
    margin-bottom: 0.4rem;
  }

  .rich-text-container :global(figure) {
    margin: 2.5rem 0;
  }

  .rich-text-container :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    display: block;
  }

  .rich-text-container :global(figcaption) {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
    text-align: center;
  }

  .rich-text-container :global(strong) {
    color: var(--color-white);
    font-weight: 700;
  }

  .rich-text-container :global(a) {
    color: #e62117;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rich-text-container :global(blockquote) {
    border-left: 3px solid #e62117;
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.5rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .rich-text-container :global(code) {
    font-family: monospace;
    background: rgba(255,255,255,0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  @media (max-width: 768px) {
    .rich-text-container {
      padding: 32px 24px 40px;
      font-size: 1.05rem;
    }

    .qs-title--plain {
      padding: 32px 24px 0;
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .qs-hero {
      height: 260px;
    }

    .qs-hero-overlay {
      padding: 24px;
    }
  }
</style>
