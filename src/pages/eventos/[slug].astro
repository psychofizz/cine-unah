---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import { client } from "../../../tina/__generated__/client";
import { Image } from "astro:assets";

const { slug } = Astro.params;

let event: any = null;
try {
    const result = await client.queries.evento({ relativePath: `${slug}.md` });
    event = result.data?.evento;
} catch (e) {
    console.error("Error fetching evento by relativePath:", e);
}

// Fallback search
if (!event) {
    try {
        const connResult = await client.queries.eventoConnection();
        const edges = connResult.data.eventoConnection.edges ?? [];
        const match = edges.find(
            (edge: any) => edge.node._sys.filename === slug,
        );
        if (match) event = match.node;
    } catch (e) {
        // Fallback also failed
    }
}

if (!event) {
    return Astro.redirect("/404");
}

const formattedDate = new Date(event.date).toLocaleDateString("es-MX", {
    timeZone: "America/Tegucigalpa",
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
});
const weekday = new Date(event.date).toLocaleDateString("es-MX", {
    timeZone: "America/Tegucigalpa",
    weekday: "long",
});
---

<BaseLayout
    title={event.title}
    description={event.description?.slice(0, 155) ??
        `${event.title} — Cine UNAH`}
    image={event.poster}
    pathname={`/eventos/${Astro.params.slug}`}
>
    <div class="container">
        <div class="detail-page">
            <a href="/" class="back-link">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Regresar
            </a>

            <div class="detail-layout">
                <!-- Poster -->
                <div class="detail-poster">
                    {
                        event.poster ? (
                            <Image
                                src={encodeURI(event.poster)}
                                alt={`Poster: ${event.title}`}
                                width={800}
                                height={1200}
                                id="detail-poster-img"
                                class="interactive-poster"
                                title="Ampliar poster"
                            />
                        ) : (
                            <div style="aspect-ratio:2/3;background:#111;" />
                        )
                    }
                </div>

                <!-- Info -->
                <div class="detail-info">
                    <span class="detail-tag">Evento</span>
                    <h1 class="detail-title">{event.title}</h1>

                    <!-- BIG TIME BLOCK -->
                    <div
                        class="detail-time-hero"
                        aria-label={`Evento: ${weekday} ${formattedDate}${event.eventTime ? " a las " + event.eventTime : ""}${event.eventEndTime ? " hasta " + event.eventEndTime : ""}`}
                    >
                        {
                            event.eventTime && (
                                <span class="detail-time-number">
                                    {event.eventTime}
                                    {event.eventEndTime
                                        ? ` - ${event.eventEndTime}`
                                        : ""}
                                </span>
                            )
                        }
                        <div class="detail-time-info">
                            <span class="detail-time-label">Evento</span>
                            <span class="detail-date-str"
                                >{weekday}
                                {
                                    formattedDate.replace(weekday + ", ", "")
                                }</span
                            >
                        </div>
                    </div>

                    {
                        event.location && (
                            <div class="detail-meta-row">
                                <span class="detail-meta-chip">
                                    📍 {event.location}
                                </span>
                            </div>
                        )
                    }

                    <ShareButtons
                        title={event.title}
                        text={`${event.title} — ${weekday} ${event.eventTime ?? ""}${event.eventEndTime ? " - " + event.eventEndTime : ""}`}
                    />

                    {
                        event.youtubeTrailer && (
                            <button
                                id="btn-trailer"
                                class="btn-trailer"
                                data-trailer={event.youtubeTrailer}
                            >
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <polygon points="5 3 19 12 5 21 5 3" />
                                </svg>
                                Ver Tráiler
                            </button>
                        )
                    }

                    {
                        event.description && (
                            <p class="detail-synopsis">{event.description}</p>
                        )
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Trailer Modal -->
    <div id="trailer-modal" class="custom-modal hidden">
        <div class="custom-modal-backdrop" id="trailer-backdrop"></div>
        <div class="custom-modal-content">
            <button
                class="custom-modal-close"
                id="trailer-close"
                aria-label="Cerrar">&times;</button
            >
            <div class="video-container" id="video-container"></div>
        </div>
    </div>

    <!-- Poster Modal -->
    <div id="poster-modal" class="custom-modal hidden">
        <div class="custom-modal-backdrop" id="poster-backdrop"></div>
        <div class="custom-modal-content poster-modal-content">
            <button
                class="custom-modal-close"
                id="poster-close"
                aria-label="Cerrar">&times;</button
            >
            {
                event.poster && (
                    <Image
                        src={encodeURI(event.poster)}
                        alt="Poster Ampliado"
                        class="poster-fullscreen"
                        width={1200}
                        height={1800}
                    />
                )
            }
        </div>
    </div>
</BaseLayout>

<style>
    .interactive-poster {
        cursor: zoom-in;
        transition: transform 0.3s ease;
    }
    .interactive-poster:hover {
        transform: scale(1.02);
    }
    .btn-trailer {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #e62117;
        color: #fff;
        padding: 10px 20px;
        border-radius: 4px;
        font-family: var(--font-sans);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 16px;
        margin-bottom: 16px;
        transition: background 0.2s ease;
    }
    .btn-trailer:hover {
        background: #cc1d14;
    }
    .custom-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .custom-modal:not(.hidden) {
        opacity: 1;
        pointer-events: auto;
    }
    .custom-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
    }
    .custom-modal-content {
        position: relative;
        z-index: 1001;
        width: 90%;
        max-width: 900px;
        background: #000;
        border-radius: 8px;
        overflow: visible;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    }
    .poster-modal-content {
        background: transparent;
        box-shadow: none;
        display: flex;
        justify-content: center;
        align-items: center;
        max-height: 90vh;
    }
    .poster-fullscreen {
        max-height: 90vh;
        max-width: 100%;
        object-fit: contain;
    }
    .custom-modal-close {
        position: absolute;
        top: -40px;
        right: 0;
        color: #fff;
        font-size: 32px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
    }
    @media (max-width: 768px) {
        .custom-modal-close {
            top: 10px;
            right: 10px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
            z-index: 1002;
        }
    }
    .video-container {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 */
        height: 0;
        overflow: hidden;
        border-radius: 8px;
    }
    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }
</style>

<script>
    function getYouTubeId(urlOrId: string | null) {
        if (!urlOrId) return null;
        const regExp =
            /^.*(youtu\.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = urlOrId.match(regExp);
        if (match && match[2].length === 11) {
            return match[2];
        } else if (urlOrId.length === 11) {
            return urlOrId;
        }
        return null;
    }

    const btnTrailer = document.getElementById("btn-trailer");
    const trailerModal = document.getElementById("trailer-modal");
    const trailerClose = document.getElementById("trailer-close");
    const trailerBackdrop = document.getElementById("trailer-backdrop");
    const videoContainer = document.getElementById("video-container");

    if (btnTrailer && trailerModal) {
        btnTrailer.addEventListener("click", () => {
            const rawUrl = btnTrailer.getAttribute("data-trailer");
            const ytId = getYouTubeId(rawUrl);
            if (ytId && videoContainer) {
                videoContainer.innerHTML = `<iframe src="https://www.youtube.com/embed/${ytId}?autoplay=1" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
            } else if (videoContainer) {
                videoContainer.innerHTML = `<div style="color:white;padding:2rem;">El enlace proporcionado no es un video válido de YouTube.</div>`;
            }
            trailerModal.classList.remove("hidden");
            document.body.style.overflow = "hidden";
        });

        const closeTrailer = () => {
            trailerModal.classList.add("hidden");
            if (videoContainer) videoContainer.innerHTML = "";
            document.body.style.overflow = "";
        };

        trailerClose?.addEventListener("click", closeTrailer);
        trailerBackdrop?.addEventListener("click", closeTrailer);
    }

    const posterImg = document.getElementById("detail-poster-img");
    const posterModal = document.getElementById("poster-modal");
    const posterClose = document.getElementById("poster-close");
    const posterBackdrop = document.getElementById("poster-backdrop");

    if (posterImg && posterModal) {
        posterImg.addEventListener("click", () => {
            posterModal.classList.remove("hidden");
            document.body.style.overflow = "hidden";
        });

        const closePoster = () => {
            posterModal.classList.add("hidden");
            document.body.style.overflow = "";
        };

        posterClose?.addEventListener("click", closePoster);
        posterBackdrop?.addEventListener("click", closePoster);
    }
</script>
