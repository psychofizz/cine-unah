---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import { client } from "../../../tina/__generated__/client";
import { Image } from "astro:assets";

export async function getStaticPaths() {
    try {
        const result = await client.queries.eventoConnection();
        const edges = result.data.eventoConnection.edges ?? [];
        return edges.map((edge: any) => ({
            params: { slug: edge.node._sys.filename },
            props: { event: edge.node },
        }));
    } catch {
        return [];
    }
}

const { event } = Astro.props;

const formattedDate = new Date(event.date).toLocaleDateString("es-MX", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
});
const weekday = new Date(event.date).toLocaleDateString("es-MX", {
    weekday: "long",
});
---

<BaseLayout
    title={event.title}
    description={event.description?.slice(0, 155) ??
        `${event.title} — Cine UNAH`}
    image={event.poster}
    pathname={`/eventos/${Astro.params.slug}`}
>
    <div class="container">
        <div class="detail-page">
            <a href="/" class="back-link">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Regresar
            </a>

            <div class="detail-layout">
                <!-- Poster -->
                <div class="detail-poster">
                    {
                        event.poster ? (
                            <Image
                                src={encodeURI(event.poster)}
                                alt={`Poster: ${event.title}`}
                                inferSize={true}
                            />
                        ) : (
                            <div style="aspect-ratio:2/3;background:#111;" />
                        )
                    }
                </div>

                <!-- Info -->
                <div class="detail-info">
                    <span class="detail-tag">Evento</span>
                    <h1 class="detail-title">{event.title}</h1>

                    <!-- BIG TIME BLOCK -->
                    <div
                        class="detail-time-hero"
                        aria-label={`Evento: ${weekday} ${formattedDate}${event.eventTime ? " a las " + event.eventTime : ""}${event.eventEndTime ? " hasta " + event.eventEndTime : ""}`}
                    >
                        {
                            event.eventTime && (
                                <span class="detail-time-number">
                                    {event.eventTime}
                                    {event.eventEndTime
                                        ? ` - ${event.eventEndTime}`
                                        : ""}
                                </span>
                            )
                        }
                        <div class="detail-time-info">
                            <span class="detail-time-label">Evento</span>
                            <span class="detail-date-str"
                                >{weekday}
                                {
                                    formattedDate.replace(weekday + ", ", "")
                                }</span
                            >
                        </div>
                    </div>

                    {
                        event.location && (
                            <div class="detail-meta-row">
                                <span class="detail-meta-chip">
                                    📍 {event.location}
                                </span>
                            </div>
                        )
                    }

                    <ShareButtons
                        title={event.title}
                        text={`${event.title} — ${weekday} ${event.eventTime ?? ""}${event.eventEndTime ? " - " + event.eventEndTime : ""}`}
                    />

                    {
                        event.description && (
                            <p class="detail-synopsis">{event.description}</p>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
