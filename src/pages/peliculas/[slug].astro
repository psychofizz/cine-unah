---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import { client } from "../../../tina/__generated__/client";
import { Image } from "astro:assets";

export async function getStaticPaths() {
    try {
        const result = await client.queries.peliculaConnection();
        const edges = result.data.peliculaConnection.edges ?? [];
        return edges.map((edge: any) => ({
            params: { slug: edge.node._sys.filename },
            props: { movie: edge.node },
        }));
    } catch {
        return [];
    }
}

const { movie } = Astro.props;

const formattedDate = new Date(movie.showDate).toLocaleDateString("es-MX", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
});
const weekday = new Date(movie.showDate).toLocaleDateString("es-MX", {
    weekday: "long",
});

const statusLabel: Record<string, string> = {
    current: "En cartelera",
    next: "Próxima proyección",
    past: "Archivo",
};
---

<BaseLayout
    title={movie.title}
    description={movie.synopsis?.slice(0, 155) ?? `${movie.title} — Cine UNAH`}
    image={movie.poster}
    pathname={`/peliculas/${Astro.params.slug}`}
>
    <div class="container">
        <div class="detail-page">
            <a href="/" class="back-link">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Regresar
            </a>

            <div class="detail-layout">
                <!-- Poster -->
                <div class="detail-poster">
                    {
                        movie.poster ? (
                            <Image
                                src={movie.poster}
                                alt={`Poster: ${movie.title}`}
                                width={600}
                                height={900}
                            />
                        ) : (
                            <div style="aspect-ratio:2/3;background:#111;" />
                        )
                    }
                </div>

                <!-- Info -->
                <div class="detail-info">
                    <span class="detail-tag"
                        >{statusLabel[movie.status] ?? movie.status}</span
                    >
                    <h1 class="detail-title">{movie.title}</h1>

                    <!-- BIG TIME BLOCK -->
                    <div
                        class="detail-time-hero"
                        aria-label={`Proyección: ${weekday} ${formattedDate}${movie.showTime ? " a las " + movie.showTime : ""}`}
                    >
                        {
                            movie.showTime && (
                                <span class="detail-time-number">
                                    {movie.showTime}
                                </span>
                            )
                        }
                        <div class="detail-time-info">
                            <span class="detail-time-label">Proyección</span>
                            <span class="detail-date-str"
                                >{weekday}
                                {
                                    formattedDate.replace(weekday + ", ", "")
                                }</span
                            >
                        </div>
                    </div>

                    {
                        (movie.country || movie.duration) && (
                            <div class="detail-meta-row">
                                {movie.country && (
                                    <span class="detail-meta-chip">
                                        {movie.country}
                                    </span>
                                )}
                                {movie.duration && (
                                    <span class="detail-meta-chip">
                                        {movie.duration} min
                                    </span>
                                )}
                            </div>
                        )
                    }

                    <ShareButtons
                        title={movie.title}
                        text={`${movie.title} — ${weekday} ${movie.showTime ?? ""}`}
                    />

                    {
                        movie.synopsis && (
                            <p class="detail-synopsis">{movie.synopsis}</p>
                        )
                    }

                    {
                        movie.credits && (
                            <div>
                                <p class="detail-credits-heading">Créditos</p>
                                <p class="detail-credits">{movie.credits}</p>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</BaseLayout>
