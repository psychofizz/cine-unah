---
import BaseLayout from "../layouts/BaseLayout.astro";
import MovieCard from "../components/MovieCard.astro";
import EventCard from "../components/EventCard.astro";
import { client } from "../../tina/__generated__/client";
import { Image } from "astro:assets";

// ── Fetch data ─────────────────────────────────────────
let allMovies: any[] = [];
let allEvents: any[] = [];
const now = new Date();
const todayStr = new Date().toLocaleDateString("en-CA", {
	timeZone: "America/Tegucigalpa",
});

try {
	const pelRes = await client.queries.peliculaConnection();
	allMovies = (pelRes.data.peliculaConnection.edges ?? []).map(
		(e: any) => e.node,
	);

	const evtRes = await client.queries.eventoConnection();
	allEvents = (evtRes.data.eventoConnection.edges ?? []).map(
		(e: any) => e.node,
	);
} catch (err) {
	console.warn("TinaCMS data not available.", err);
}

// ── Hero logic ─────────────────────────────────────────
// Priority 1: a movie/event with featured:true whose date hasn't passed yet
// Priority 2: the most upcoming movie (current or next) by date
// Priority 3: the most upcoming future event by date

function slugFromFilename(f: string) {
	return f.replace(/\.md$/, "");
}

const activeMovies = allMovies.filter((m: any) => {
	if (!m.showDate) return false;
	const showDateStr = new Date(m.showDate).toLocaleDateString("en-CA", {
		timeZone: "America/Tegucigalpa",
	});
	return showDateStr >= todayStr;
});

const futureEvents = allEvents.filter((e: any) => {
	if (!e.date) return false;
	const eventDateStr = new Date(e.date).toLocaleDateString("en-CA", {
		timeZone: "America/Tegucigalpa",
	});
	return eventDateStr >= todayStr;
});

// Find a featured item
const featuredMovie =
	activeMovies.find((m: any) => m.featured === true) ?? null;
const featuredEvent =
	allEvents.find(
		(e: any) =>
			e.featured === true &&
			new Date(e.date).toLocaleDateString("en-CA", {
				timeZone: "America/Tegucigalpa",
			}) >= todayStr,
	) ?? null;

// Decide hero item (featured beats proximity)
let heroType: "movie" | "event" | null = null;
let heroItem: any = null;

if (featuredMovie || featuredEvent) {
	// Prefer the explicitly featured one; if both, pick movie
	if (featuredMovie) {
		heroType = "movie";
		heroItem = featuredMovie;
	} else {
		heroType = "event";
		heroItem = featuredEvent;
	}
} else if (activeMovies.length > 0) {
	heroType = "movie";
	heroItem = activeMovies.sort(
		(a: any, b: any) =>
			new Date(a.showDate).getTime() - new Date(b.showDate).getTime(),
	)[0];
} else if (futureEvents.length > 0) {
	heroType = "event";
	heroItem = futureEvents.sort(
		(a: any, b: any) =>
			new Date(a.date).getTime() - new Date(b.date).getTime(),
	)[0];
}

// ── Grid movies — show ALL active movies (hero stays in grid too) ──
const gridMovies = activeMovies;

// ── Upcoming events (exclude hero if it's an event) ──────
const upcomingEvents = futureEvents
	.filter(
		(e: any) =>
			heroType !== "event" ||
			e._sys.filename !== heroItem?._sys?.filename,
	)
	.sort(
		(a: any, b: any) =>
			new Date(a.date).getTime() - new Date(b.date).getTime(),
	);

// ── Format helpers ────────────────────────────────────────
function formatHeroDate(dateStr: string) {
	const d = new Date(dateStr);
	return {
		weekday: d.toLocaleDateString("es-MX", {
			timeZone: "America/Tegucigalpa",
			weekday: "long",
		}),
		full: d.toLocaleDateString("es-MX", {
			timeZone: "America/Tegucigalpa",
			day: "numeric",
			month: "long",
			year: "numeric",
		}),
	};
}
---

<BaseLayout
	title="Cartelera"
	description="Cartelera de Cine UNAH — películas y eventos universitarios."
	image={heroItem?.poster ?? ""}
>
	<!-- ════════════════════════════════════════════
       HERO — featured or most upcoming
  ════════════════════════════════════════════ -->
	{
		heroItem
			? (() => {
					const isMovie = heroType === "movie";
					const dateStr = isMovie ? heroItem.showDate : heroItem.date;
					const time = isMovie
						? heroItem.showTime
						: heroItem.eventTime;
					const slug = slugFromFilename(heroItem._sys.filename);
					const href = isMovie
						? `/peliculas/${slug}`
						: `/eventos/${slug}`;
					const { weekday, full } = formatHeroDate(dateStr);
					return (
						<section
							class="hero"
							aria-label="Presentación destacada"
						>
							{/* Background poster */}
							<div class="hero-poster-bg">
								{heroItem.poster ? (
									<Image
										src={encodeURI(heroItem.poster)}
										alt=""
										aria-hidden="true"
										inferSize={true}
									/>
								) : (
									<div class="hero-poster-bg-empty" />
								)}
							</div>
							<div class="hero-gradient" aria-hidden="true" />

							<div class="hero-content container">
								{/* Thumbnail poster */}
								<div class="hero-poster-thumb">
									{heroItem.poster ? (
										<Image
											src={encodeURI(heroItem.poster)}
											alt={`Poster: ${heroItem.title}`}
											inferSize={true}
										/>
									) : (
										<div style="aspect-ratio:2/3;background:#1a1a1a;" />
									)}
								</div>

								{/* Info */}
								<div class="hero-info">
									<span class="hero-label">
										<span
											class="hero-label-dot"
											aria-hidden="true"
										/>
										{isMovie
											? heroItem.status === "current"
												? "En cartelera"
												: "Próxima proyección"
											: "Evento"}
									</span>

									<h1
										class={`hero-title${!isMovie ? " hero-title-event" : ""}`}
									>
										{heroItem.title}
									</h1>

									{/* BIG TIME */}
									<div
										class="hero-datetime"
										aria-label={`Fecha y hora: ${weekday} ${full} a las ${time}`}
									>
										{time && (
											<span class="hero-time-big">
												{time}
											</span>
										)}
										<div class="hero-date-block">
											<span class="hero-date-day">
												{weekday}
											</span>
											<span class="hero-date-full">
												{full}
											</span>
										</div>
									</div>

									{/* Meta chips */}
									<div class="hero-meta">
										{isMovie && heroItem.duration && (
											<span class="hero-chip">
												{heroItem.duration} min
											</span>
										)}
										{isMovie && heroItem.country && (
											<span class="hero-chip">
												{heroItem.country}
											</span>
										)}
										{!isMovie && heroItem.location && (
											<span class="hero-chip">
												📍 {heroItem.location}
											</span>
										)}
									</div>

									<div class="hero-actions">
										<a href={href} class="hero-btn-primary">
											Ver detalle
											<svg
												width="14"
												height="14"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2.5"
												aria-hidden="true"
											>
												<path d="M5 12h14M12 5l7 7-7 7" />
											</svg>
										</a>
									</div>
								</div>
							</div>
						</section>
					);
				})()
			: null
	}

	<div class="container">
		<!-- PELICULAS EN CARTELERA -->
		{
			gridMovies.length > 0 && (
				<section class="section" aria-labelledby="cartelera-title">
					<div class="section-header">
						<h2 class="section-title" id="cartelera-title">
							En Cartelera
						</h2>
						<div class="section-line" aria-hidden="true" />
					</div>
					<div class="grid-movies">
						{gridMovies.map((movie: any) => (
							<MovieCard
								slug={slugFromFilename(movie._sys.filename)}
								title={movie.title}
								poster={movie.poster}
								showDate={movie.showDate}
								showTime={movie.showTime}
								showEndTime={movie.showEndTime}
								country={movie.country}
								duration={movie.duration}
							/>
						))}
					</div>
				</section>
			)
		}

		{
			gridMovies.length === 0 && !heroItem && (
				<section class="section">
					<div class="section-header">
						<h2 class="section-title">En Cartelera</h2>
						<div class="section-line" />
					</div>
					<div class="empty-state">
						<div class="empty-state-icon" aria-hidden="true">
							🎬
						</div>
						<p class="empty-state-text">
							Próximamente — añade películas desde el panel de
							administración.
						</p>
					</div>
				</section>
			)
		}

		{
			gridMovies.length > 0 && upcomingEvents.length > 0 && (
				<hr class="divider" aria-hidden="true" />
			)
		}

		<!-- EVENTOS -->
		{
			upcomingEvents.length > 0 && (
				<section class="section" aria-labelledby="eventos-title">
					<div class="section-header">
						<h2 class="section-title" id="eventos-title">
							Próximos Eventos
						</h2>
						<div class="section-line" aria-hidden="true" />
					</div>
					<div class="grid-events">
						{upcomingEvents.map((event: any) => (
							<EventCard
								slug={slugFromFilename(event._sys.filename)}
								title={event.title}
								poster={event.poster}
								date={event.date}
								eventTime={event.eventTime}
								eventEndTime={event.eventEndTime}
								location={event.location}
							/>
						))}
					</div>
				</section>
			)
		}
	</div>
</BaseLayout>
