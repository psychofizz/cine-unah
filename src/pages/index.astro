---
import BaseLayout from "../layouts/BaseLayout.astro";
import MovieCard from "../components/MovieCard.astro";
import EventCard from "../components/EventCard.astro";
import { client } from "../../tina/__generated__/client";
import { Image } from "astro:assets";
import { resolveLocation } from "../utils/resolveLocation";
import { formatEventDates, toCalendarDate } from "../utils/dateFormatter";

// ── Fetch data ─────────────────────────────────────────
let allMovies: any[] = [];
let allEvents: any[] = [];
const now = new Date();
const todayStr = new Date().toLocaleDateString("en-CA", {
	timeZone: "America/Tegucigalpa",
});

try {
	const pelRes = await client.queries.peliculaConnection({ first: 200 });
	allMovies = (pelRes.data.peliculaConnection.edges ?? []).map(
		(e: any) => e.node,
	);

	const evtRes = await client.queries.eventoConnection();
	allEvents = (evtRes.data.eventoConnection.edges ?? []).map(
		(e: any) => e.node,
	);
} catch (err) {
	console.warn("TinaCMS data not available.", err);
}

// Fallback to local files if TinaCMS query returns empty or failed
if (!allMovies || allMovies.length === 0) {
	const localMoviesGlob = import.meta.glob("../content/peliculas/*.md", { eager: true });
	allMovies = Object.entries(localMoviesGlob).map(([filePath, mod]: any) => {
		const filename = filePath.split("/").pop()?.replace(/\.md$/, "") || "";
		return {
			_sys: { filename },
			id: filename,
			...mod.frontmatter,
		};
	});
}

if (!allEvents || allEvents.length === 0) {
	const localEventsGlob = import.meta.glob("../content/eventos/*.md", { eager: true });
	allEvents = Object.entries(localEventsGlob).map(([filePath, mod]: any) => {
		const filename = filePath.split("/").pop()?.replace(/\.md$/, "") || "";
		return {
			_sys: { filename },
			id: filename,
			...mod.frontmatter,
		};
	});
}

const nowTimeStr = new Date().toLocaleTimeString("en-GB", {
	timeZone: "America/Tegucigalpa",
	hour: "2-digit",
	minute: "2-digit",
});

// ── Upcoming 7 days window (including today) in Tegucigalpa ──
const [yr, mo, dy] = todayStr.split("-").map(Number);
const dateObj = new Date(Date.UTC(yr, mo - 1, dy));

const sevenDaysLater = new Date(dateObj);
sevenDaysLater.setUTCDate(dateObj.getUTCDate() + 7);
const sevenDaysLaterStr = sevenDaysLater.toISOString().slice(0, 10); // YYYY-MM-DD

function addMinutes(timeStr: string, mins: number) {
	const [h, m] = timeStr.split(":").map(Number);
	const d = new Date();
	d.setHours(h, m + mins, 0, 0);
	return `${d.getHours().toString().padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")}`;
}

const activeMovies = allMovies.filter((m: any) => {
	if (m.hiddenFromCartelera) return false;
	if (!m.showDate) return false;
	// Use the YYYY-MM-DD portion directly to avoid UTC->local timezone shift
	const showDateStr = toCalendarDate(m.showDate);

	if (showDateStr < todayStr) return false;
	if (!m.forceShow && showDateStr > sevenDaysLaterStr) return false;
	if (showDateStr === todayStr) {
		const endTime = m.showEndTime || (() => {
			if (!m.showTime) return "";
			const [h, mStr] = m.showTime.split(":");
			return `${(parseInt(h) + 2).toString().padStart(2, "0")}:${mStr}`;
		})();
		if (endTime) {
			const dropTime = addMinutes(endTime, 15);
			if (nowTimeStr > dropTime) return false;
		}
	}
	return true;
});

const futureEvents = allEvents.filter((e: any) => {
	if (!e.date) return false;
	// Use the YYYY-MM-DD portion directly to avoid UTC->local timezone shift
	const eventDateStr = toCalendarDate(e.endDate || e.date);

	if (eventDateStr < todayStr) return false;
	if (!e.forceShow && eventDateStr > sevenDaysLaterStr) return false;
	if (eventDateStr === todayStr) {
		const endTime = e.eventEndTime || (() => {
			if (!e.eventTime) return "";
			const [h, mStr] = e.eventTime.split(":");
			return `${(parseInt(h) + 2).toString().padStart(2, "0")}:${mStr}`;
		})();
		if (endTime) {
			const dropTime = addMinutes(endTime, 15);
			if (nowTimeStr > dropTime) return false;
		}
	}
	return true;
});

const isPastMovie = (m: any) => {
	const showDateStr = toCalendarDate(m.showDate);
	if (showDateStr < todayStr) return true;
	if (showDateStr === todayStr) {
		const endTime = m.showEndTime || (() => {
			if (!m.showTime) return "";
			const [h, mStr] = m.showTime.split(":");
			return `${(parseInt(h) + 2).toString().padStart(2, "0")}:${mStr}`;
		})();
		if (endTime && nowTimeStr > endTime) return true;
	}
	return false;
};

const isPastEvent = (e: any) => {
	const eventDateStr = toCalendarDate(e.endDate || e.date);
	if (eventDateStr < todayStr) return true;
	if (eventDateStr === todayStr) {
		const endTime = e.eventEndTime || (() => {
			if (!e.eventTime) return "";
			const [h, mStr] = e.eventTime.split(":");
			return `${(parseInt(h) + 2).toString().padStart(2, "0")}:${mStr}`;
		})();
		if (endTime && nowTimeStr > endTime) return true;
	}
	return false;
};

// The carousel shows all active non-reservado movies and future events coming up, sorted by ended-status, then date and time
const heroCarouselItems = [
	...activeMovies.filter((m: any) => m.category !== "reservado"),
	...futureEvents
].sort((a: any, b: any) => {
	const aPast = a.showDate ? isPastMovie(a) : isPastEvent(a);
	const bPast = b.showDate ? isPastMovie(b) : isPastEvent(b);

	// Ended (past) items go to the end
	if (aPast !== bPast) return aPast ? 1 : -1;

	const dateAStr = toCalendarDate(a.showDate || a.date);
	const dateBStr = toCalendarDate(b.showDate || b.date);
	if (dateAStr !== dateBStr) return dateAStr.localeCompare(dateBStr);

	const timeA = a.showTime || a.eventTime || "00:00";
	const timeB = b.showTime || b.eventTime || "00:00";
	return timeA.localeCompare(timeB);
});

// ── Grid movies — show ALL active movies of the upcoming 7 days (unless forceShow is true) ──
const gridMovies = [...activeMovies]
	.filter((m: any) => {
		if (m.forceShow) return true;
		const showDateStr = toCalendarDate(m.showDate);
		return showDateStr >= todayStr && showDateStr <= sevenDaysLaterStr;
	})
	.sort((a: any, b: any) => {
		const dateAStr = toCalendarDate(a.showDate);
		const dateBStr = toCalendarDate(b.showDate);
		if (dateAStr !== dateBStr) return dateAStr.localeCompare(dateBStr);

		const timeA = a.showTime || "00:00";
		const timeB = b.showTime || "00:00";
		return timeA.localeCompare(timeB);
	});

// ── Upcoming events ──────
const upcomingEvents = futureEvents.sort(
	(a: any, b: any) => new Date(a.date).getTime() - new Date(b.date).getTime(),
);

function slugFromFilename(f: string) {
	return f.replace(/\.md$/, "");
}

// ── Format helpers ────────────────────────────────────────
function formatHeroDate(dateStr: string) {
	// Parse at UTC midnight using the YYYY-MM-DD portion to avoid timezone shift
	const d = new Date(toCalendarDate(dateStr) + "T00:00:00Z");
	return {
		weekday: d.toLocaleDateString("es-MX", {
			timeZone: "UTC",
			weekday: "long",
		}),
		full: d.toLocaleDateString("es-MX", {
			timeZone: "UTC",
			day: "numeric",
			month: "long",
			year: "numeric",
		}),
	};
}
---

<BaseLayout
	title="Cartelera"
	description="Cartelera de Cine UNAH — películas y eventos universitarios."
	image={heroCarouselItems[0]?.poster ?? ""}
>
	<!-- ════════════════════════════════════════════
       HERO CAROUSEL — active movies
  ════════════════════════════════════════════ -->
	{
		heroCarouselItems.length > 0 && (
			<div class="hero-carousel-wrapper">
				<div class="hero-carousel" id="heroCarousel">
					{heroCarouselItems.map((movie: any, index: number) => {
						const isEvent = !!movie.eventTime;
						const dateStr = movie.showDate || movie.date;
						const time = movie.showTime || movie.eventTime || "00:00";
						const endTime = movie.showEndTime || movie.eventEndTime || "";
						const slug = slugFromFilename(movie._sys.filename);
						const href = isEvent ? `/eventos/${slug}` : `/peliculas/${slug}`;
						
						let weekdayVal = "";
						let fullVal = "";
						if (isEvent) {
							const dateRange = formatEventDates(movie.date, movie.endDate);
							weekdayVal = dateRange.weekday;
							fullVal = dateRange.fullDate;
						} else {
							const hDate = formatHeroDate(dateStr);
							weekdayVal = hDate.weekday.charAt(0).toUpperCase() + hDate.weekday.slice(1);
							fullVal = hDate.full;
						}

						return (
							<section
								class="hero hero-slide"
								id={`hero-slide-${index}`}
								data-date={dateStr}
								data-time={time}
								data-end-time={endTime}
								data-cancelled={movie.cancelled ? "true" : "false"}
								aria-label={`${isEvent ? 'Evento' : 'Película'} destacada: ${movie.title}`}
							>
								{/* Background poster */}
								<div class="hero-poster-bg">
									{movie.poster ? (
										<Image
											src={encodeURI(movie.poster)}
											alt=""
											aria-hidden="true"
											width={1920}
											height={1080}
											class="w-full h-full object-cover"
										/>
									) : (
										<div class="hero-poster-bg-empty" />
									)}
								</div>
								<div class="hero-gradient" aria-hidden="true" />

								<div class="hero-content container">
									{/* Thumbnail poster */}
									<div class="hero-poster-thumb">
										{movie.poster ? (
											<div class="thumb-poster-wrapper" style="position: relative; width: 100%; height: 100%;">
												<Image
													src={encodeURI(movie.poster)}
													alt={`Poster: ${movie.title}`}
													width={400}
													height={600}
												/>
												{isEvent ? (
													<div class="event-badge">
														Evento
													</div>
												) : movie.isPartOfEvent ? (
													<div class="event-badge">
														Función Doble: {movie.isPartOfEvent.title}
													</div>
												) : null}
												{movie.cancelled && (
													<div class="card-cancelled-badge" style="top: 10px; right: 10px;" aria-label="Cancelado">
														<svg
															width="8"
															height="8"
															viewBox="0 0 24 24"
															fill="none"
															stroke="currentColor"
															stroke-width="3.5"
															stroke-linecap="round"
															aria-hidden="true"
														>
															<line x1="18" y1="6" x2="6" y2="18" />
															<line x1="6" y1="6" x2="18" y2="18" />
														</svg>
														Cancelado
													</div>
												)}
											</div>
										) : (
											<div style="aspect-ratio:2/3;background:#1a1a1a;" />
										)}
									</div>

									{/* Info */}
									<div class="hero-info">
										{movie.cancelled && (
											<span class="detail-tag detail-tag--cancelled" style="margin-bottom: var(--sp-2);">
												<svg
													width="10"
													height="10"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="3.5"
													stroke-linecap="round"
													aria-hidden="true"
												>
													<line x1="18" y1="6" x2="6" y2="18" />
													<line x1="6" y1="6" x2="18" y2="18" />
												</svg>
												Cancelado
											</span>
										)}
										<span
											class="hero-label"
											style="display: none;"
										>
											<span class="hero-label-text" />
										</span>

										<h1 class="hero-title">
											{movie.title}
										</h1>

										{/* BIG TIME */}
										<div
											class="hero-datetime"
											aria-label={`Fecha y hora: ${weekdayVal} ${fullVal} a las ${time}`}
										>
											{time && (
												<span class={`hero-time-big${movie.cancelled ? " detail-time-number--cancelled" : ""}`}>
													{time}
												</span>
											)}
											<div class="hero-date-block" style={movie.cancelled ? "opacity: 0.35;" : undefined}>
												<span class="hero-date-day">
													{weekdayVal}
												</span>
												<span class="hero-date-full">
													{fullVal}
												</span>
											</div>
										</div>

										{/* Meta chips */}
										<div class="hero-meta">
											{movie.duration && (
												<span class="hero-chip">
													{movie.duration} min
												</span>
											)}
											{movie.country && (
												<span class="hero-chip">
													{movie.country}
												</span>
											)}
											{(() => {
												const loc = resolveLocation(movie.location);
												return loc ? (
													<a href={`/ubicacion/${loc.slug}`} class="hero-chip location-link" style="text-decoration: none; display: inline-flex; align-items: center;">
														📍 {loc.title}
													</a>
												) : null;
											})()}
										</div>

										<div class="hero-actions">
											<a
												href={href}
												class="hero-btn-primary"
											>
												Ver más
												<svg
													width="14"
													height="14"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2.5"
													aria-hidden="true"
												>
													<path d="M5 12h14M12 5l7 7-7 7" />
												</svg>
											</a>
										</div>
									</div>
								</div>
							</section>
						);
					})}
				</div>

				{heroCarouselItems.length > 1 && (
					<div class="hero-carousel-controls container">
						<div class="hero-carousel-dots">
							{heroCarouselItems.map((_: any, i: number) => (
								<button
									class="hero-dot"
									data-slide={i}
									aria-label={`Ir al slide ${i + 1}`}
								/>
							))}
						</div>
						<div class="hero-nav-buttons">
							<button
								class="hero-nav-btn prev"
								aria-label="Anterior"
							>
								<svg
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
								>
									<path d="M15 18l-6-6 6-6" />
								</svg>
							</button>
							<button
								class="hero-nav-btn next"
								aria-label="Siguiente"
							>
								<svg
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
								>
									<path d="M9 18l6-6-6-6" />
								</svg>
							</button>
						</div>
					</div>
				)}

				<div class="hero-progress-bar">
					<div class="hero-progress-fill" id="heroProgressFill" />
				</div>
			</div>
		)
	}

	<div class="container">
		<!-- PELICULAS EN CARTELERA -->
		{
			gridMovies.length > 0 && (
				<section class="section" aria-labelledby="cartelera-title">
					<div class="section-header">
						<h2 class="section-title" id="cartelera-title">
							En Cartelera
						</h2>
						<div class="section-line" aria-hidden="true" />
					</div>
					<div class="grid-movies">
						{gridMovies.map((movie: any) => (
							<MovieCard
								slug={slugFromFilename(movie._sys.filename)}
								title={movie.title}
								poster={movie.poster}
								showDate={movie.showDate}
								showTime={movie.showTime}
								showEndTime={movie.showEndTime}
								country={movie.country}
								duration={movie.duration}
								location={movie.location}
								cancelled={movie.cancelled}
								category={movie.category}
							/>
						))}
					</div>
				</section>
			)
		}

		{
			gridMovies.length === 0 && heroCarouselItems.length === 0 && (
				<section class="section">
					<div class="section-header">
						<h2 class="section-title">En Cartelera</h2>
						<div class="section-line" />
					</div>
					<div class="empty-state">
						<div class="empty-state-icon" aria-hidden="true">
							🎬
						</div>
						<p class="empty-state-text">
							Estamos preparando nuestra próxima selección. Muy
							pronto anunciaremos nuevas proyecciones en nuestra
							cartelera.
						</p>
					</div>
				</section>
			)
		}

		{
			gridMovies.length > 0 && upcomingEvents.length > 0 && (
				<hr class="divider" aria-hidden="true" />
			)
		}

		<!-- EVENTOS -->
		{
			upcomingEvents.length > 0 && (
				<section class="section" aria-labelledby="eventos-title">
					<div class="section-header">
						<h2 class="section-title" id="eventos-title">
							Próximos Eventos
						</h2>
						<div class="section-line" aria-hidden="true" />
					</div>
					<div class="grid-events">
						{upcomingEvents.map((event: any) => (
							<EventCard
								slug={slugFromFilename(event._sys.filename)}
								title={event.title}
								poster={event.poster}
								date={event.date}
								endDate={event.endDate}
								eventTime={event.eventTime}
								eventEndTime={event.eventEndTime}
								location={event.location}
								cancelled={event.cancelled}
							/>
						))}
					</div>
				</section>
			)
		}
	</div>
</BaseLayout>

<script>
	const carousel = document.getElementById("heroCarousel");
	if (carousel) {
		const slides = carousel.querySelectorAll(".hero-slide");
		const dots = document.querySelectorAll(".hero-dot");
		const prevBtn = document.querySelector(".hero-nav-btn.prev");
		const nextBtn = document.querySelector(".hero-nav-btn.next");
		const progressFill = document.getElementById("heroProgressFill");

		let autoPlayInterval: ReturnType<typeof setInterval>;
		let scrollTimeout: ReturnType<typeof setTimeout>;
		const autoPlayDelay = 10000;
		let isHovered = false;
		let isAnimating = false;

		const startProgress = () => {
			if (progressFill) {
				progressFill.style.transition = "none";
				progressFill.style.width = "0%";
				// Force reflow
				void progressFill.offsetWidth;
				progressFill.style.transition = `width ${autoPlayDelay}ms linear`;
				progressFill.style.width = "100%";
			}
		};

		const stopProgress = () => {
			if (progressFill) {
				const computedWidth =
					window.getComputedStyle(progressFill).width;
				progressFill.style.transition = "none";
				progressFill.style.width = computedWidth;
			}
		};

		const smoothScrollTo = (targetScrollLeft: number, duration = 800) => {
			if (isAnimating) return;
			isAnimating = true;

			const startScrollLeft = carousel.scrollLeft;
			const distance = targetScrollLeft - startScrollLeft;
			let startTime: number | null = null;

			// Temporarily disable scroll snapping so it doesn't fight our animation
			carousel.style.scrollSnapType = "none";

			const easeInOutQuad = (
				t: number,
				b: number,
				c: number,
				d: number,
			) => {
				t /= d / 2;
				if (t < 1) return (c / 2) * t * t + b;
				t--;
				return (-c / 2) * (t * (t - 2) - 1) + b;
			};

			const animation = (currentTime: number) => {
				if (startTime === null) startTime = currentTime;
				const timeElapsed = currentTime - startTime;

				carousel.scrollLeft = easeInOutQuad(
					timeElapsed,
					startScrollLeft,
					distance,
					duration,
				);

				if (timeElapsed < duration) {
					requestAnimationFrame(animation);
				} else {
					carousel.scrollLeft = targetScrollLeft;
					carousel.style.scrollSnapType = ""; // Restore snap
					isAnimating = false;
				}
			};

			requestAnimationFrame(animation);
		};

		const advanceSlide = () => {
			const scrollLeft = carousel.scrollLeft;
			const slideWidth = carousel.clientWidth;
			let index = Math.round(scrollLeft / slideWidth);

			if (index >= slides.length - 1) {
				// Return to first slide
				smoothScrollTo(0, 800);
			} else {
				smoothScrollTo((index + 1) * slideWidth, 800);
			}
		};

		const resetAutoPlay = () => {
			clearInterval(autoPlayInterval);
			startProgress();
			autoPlayInterval = setInterval(() => {
				advanceSlide();
			}, autoPlayDelay);
		};

		const updateActiveDot = () => {
			const scrollLeft = carousel.scrollLeft;
			const slideWidth = carousel.clientWidth;
			// Use Math.round to determine which slide is most visible
			const index = Math.round(scrollLeft / slideWidth);

			dots.forEach((dot, i) => {
				if (i === index) dot.classList.add("active");
				else dot.classList.remove("active");
			});
		};

		// Initial check
		updateActiveDot();
		resetAutoPlay();

		// Update on scroll
		carousel.addEventListener(
			"scroll",
			() => {
				if (!isAnimating) {
					updateActiveDot();
				}

				// Clear intervals while snapping
				clearInterval(autoPlayInterval);
				clearTimeout(scrollTimeout);

				// Restart autoplay when scrolling stops
				scrollTimeout = setTimeout(() => {
					if (!isAnimating) {
						resetAutoPlay();
					}
				}, 150);
			},
			{ passive: true },
		);

		// Dots navigation
		dots.forEach((dot, i) => {
			dot.addEventListener("click", () => {
				smoothScrollTo(i * carousel.clientWidth, 800);
			});
		});

		// Buttons navigation
		if (prevBtn) {
			prevBtn.addEventListener("click", () => {
				const slideWidth = carousel.clientWidth;
				let index = Math.round(carousel.scrollLeft / slideWidth);
				smoothScrollTo((index - 1) * slideWidth, 800);
			});
		}
		if (nextBtn) {
			nextBtn.addEventListener("click", () => {
				const slideWidth = carousel.clientWidth;
				let index = Math.round(carousel.scrollLeft / slideWidth);
				smoothScrollTo((index + 1) * slideWidth, 800);
			});
		}
	}
</script>
